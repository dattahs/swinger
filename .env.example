# Copy to .env and fill from https://account.upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# Optional: skip browser login if you already have a token
# UPSTOX_ACCESS_TOKEN=

# Optional: auto-fill TOTP during Playwright login
# UPSTOX_TOTP_SECRET=

# Backtest results email
SWINGER_SMTP_HOST=smtp.gmail.com
SWINGER_SMTP_PORT=587
SWINGER_SMTP_USER=
SWINGER_SMTP_PASSWORD=
SWINGER_EMAIL_FROM=
SWINGER_EMAIL_TO=
SWINGER_SMTP_USE_TLS=true
