# Copy to .env and fill from https://account.upstox.com/developer/apps
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# Optional: skip browser login if you already have a token (NOT used on VPS — login cron writes token_file)
# UPSTOX_ACCESS_TOKEN=

# TOTP secret (base32) for fully_automated / totp_automated_login on VPS
# Export from your authenticator setup (otpauth://...?secret=XXXX) or re-enroll 2FA and capture QR secret
# UPSTOX_TOTP_SECRET=

# Backtest results email
SWINGER_SMTP_HOST=smtp.gmail.com
SWINGER_SMTP_PORT=587
SWINGER_SMTP_USER=
SWINGER_SMTP_PASSWORD=
SWINGER_EMAIL_FROM=
SWINGER_EMAIL_TO=
SWINGER_SMTP_USE_TLS=true

# Live GTT alerts (Telegram + email when orders placed/updated/cancelled on Upstox)
SWINGER_TELEGRAM_BOT_TOKEN=
SWINGER_TELEGRAM_CHAT_ID=
