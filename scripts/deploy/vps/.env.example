# Live Upstox credentials for VPS (pushed from laptop_env in deploy.config.yaml)
# Register redirect URI: http://127.0.0.1:5000/callback
# Whitelist VPS IP in Upstox developer console.

UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:5000/callback

# Not synced to VPS — use login cron + shared/data/live/upstox_token.json
# UPSTOX_ACCESS_TOKEN=

# Base32 TOTP secret (required for fully_automated / totp_automated_login)
UPSTOX_TOTP_SECRET=

# GTT alerts (synced to VPS shared/.env on push)
SWINGER_TELEGRAM_BOT_TOKEN=
SWINGER_TELEGRAM_CHAT_ID=
SWINGER_SMTP_HOST=smtp.gmail.com
SWINGER_SMTP_PORT=587
SWINGER_SMTP_USER=
SWINGER_SMTP_PASSWORD=
SWINGER_EMAIL_FROM=
SWINGER_EMAIL_TO=
SWINGER_SMTP_USE_TLS=true
